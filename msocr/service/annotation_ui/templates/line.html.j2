<!DOCTYPE html>
<html lang="sog" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Annotation — {{ session_id }} / line {{ line_n }}</title>
  <script src="/static/htmx.min.js"></script>
  <script defer src="/static/alpine.min.js"></script>
  <style>
    :root { --fg: #1a1a1a; --bg: #fafafa; --border: #c0c0c0; --accent: #0066cc; }
    body { font-family: "Noto Sans Sogdian", "Segoe UI", system-ui, sans-serif;
           max-width: 42em; margin: 0 auto; padding: 1.5em 1em;
           color: var(--fg); background: var(--bg); }
    .progress { color: #666; font-size: 0.9em; margin-bottom: 0.5em; }
    .line-img { max-width: 100%; border: 1px solid var(--border); border-radius: 4px;
                display: block; margin: 0.5em 0; }
    .transcription { width: 100%; font-size: 1.5em; padding: 0.6em;
                     direction: rtl; font-family: "Noto Sans Sogdian", serif;
                     border: 1px solid var(--border); border-radius: 4px;
                     min-height: 2.5em; box-sizing: border-box; }
    .palette { margin: 0.6em 0; }
    .palette button { font-size: 1.3em; padding: 0.2em 0.5em; margin: 0.1em;
                     border: 1px solid var(--border); background: #fff;
                     border-radius: 3px; cursor: pointer; font-family: inherit; }
    .palette button:hover { background: #f0f0f0; }
    .controls { display: flex; gap: 0.5em; justify-content: center; margin-top: 1em; }
    .controls button { padding: 0.5em 1.2em; font-size: 1em; cursor: pointer;
                       border: 1px solid var(--border); border-radius: 4px;
                       background: #fff; font-family: inherit; }
    .controls button#save { background: var(--accent); color: #fff; border-color: var(--accent); }
    .controls button#save:hover { opacity: 0.9; }
    .kbd-hint { font-size: 0.8em; color: #888; text-align: center; margin-top: 0.4em; }
  </style>
</head>
<body x-data="{ trans: {{ current_text | tojson }} }"
      @keydown.arrow-up.prevent="document.getElementById('prev').click()"
      @keydown.arrow-down.prevent="document.getElementById('save').click()">
  <p class="progress">line {{ line_n }} / {{ total_lines }}</p>
  <img class="line-img" src="/api/sessions/{{ session_id }}/line/{{ line_n }}/image"
       alt="line {{ line_n }}">
  <form hx-post="/api/sessions/{{ session_id }}/line/{{ line_n }}/save"
        hx-trigger="submit"
        hx-on::after-request="document.getElementById('next').click()">
    <textarea class="transcription" name="transcription" x-model="trans"
              dir="rtl" lang="sog" placeholder="transcribe..." autofocus></textarea>
    {% include "sogdian_keyboard.html" %}
    <div class="controls">
      <button type="button" id="prev"
              onclick="window.location.href='/ui/{{ session_id }}/{{ prev_line_n }}'">← prev</button>
      <button type="submit" id="save">save (⏎)</button>
      <button type="button" id="next"
              onclick="window.location.href='/ui/{{ session_id }}/{{ next_line_n }}'">next →</button>
    </div>
    <p class="kbd-hint">↑ prev · ↓/⏎ save+next</p>
  </form>
</body>
</html>
