<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ plan_title }}</title>
  <style>
    :root { --fg: #1a1a1a; --bg: #fafafa; --border: #d0d0d0; --code-bg: #f0f0f0; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
           max-width: 48em; margin: 0 auto; padding: 2em 1em; line-height: 1.65;
           color: var(--fg); background: var(--bg); }
    h1 { border-bottom: 2px solid var(--border); padding-bottom: 0.3em; }
    h2 { margin-top: 1.8em; border-bottom: 1px solid var(--border); padding-bottom: 0.2em; }
    h3 { margin-top: 1.4em; }
    pre { background: var(--code-bg); padding: 1em; overflow-x: auto; border-radius: 4px; font-size: 0.9em; }
    code { background: var(--code-bg); padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.9em; }
    pre code { background: none; padding: 0; }
    table { border-collapse: collapse; margin: 1em 0; }
    th, td { border: 1px solid var(--border); padding: 0.4em 0.8em; text-align: left; }
    th { background: var(--code-bg); }
    blockquote { border-left: 3px solid var(--border); margin: 1em 0; padding-left: 1em; color: #555; }
    a { color: #0066cc; }
  </style>
</head>
<body>
  <h1>{{ plan_title }}</h1>
  {{ plan_html | safe }}
</body>
</html>
